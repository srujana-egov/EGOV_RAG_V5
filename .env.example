# ── Database (PostgreSQL / Neon) ──────────────────────────────
PGHOST=your-neon-host.neon.tech
PGDATABASE=your_db_name
PGUSER=your_db_user
PGPASSWORD=your_db_password
PGPORT=5432

# ── OpenAI ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── App behaviour ─────────────────────────────────────────────
# Password-protect the app. Leave unset for open access (dev mode).
APP_PASSWORD=

# Domain identity — shown in UI title, system prompt, and out-of-domain message
# Change for other deployments (e.g. "HCM", "Health Campaign Management")
APP_DOMAIN=DIGIT Studio

# Rate limiting: max queries per window (per session)
MAX_QUERIES_PER_WINDOW=20
RATE_WINDOW_SECONDS=60

# RAG domain detection: cosine similarity below this = out of domain
OUT_OF_DOMAIN_THRESHOLD=0.35

# ── AWS Secrets Manager (optional) ────────────────────────────
# If set, secrets are fetched from this AWS secret instead of env vars.
# AWS_SECRET_NAME=my-egov-rag-secret
# AWS_REGION=ap-south-1

# ── DB table name (optional, default: studio_manual) ──────────
# DB_TABLE=studio_manual

# ── Multi-domain table overrides (optional) ──────────────────
# Override table names for separate domain deployments.
# Leave unset to use defaults (predetermined_qa, query_history, etc.)
# QA_TABLE=hcm_predetermined_qa
# QUERY_HISTORY_TABLE=hcm_query_history
# FEEDBACK_TABLE=hcm_bot_feedback
# VOTE_LOG_TABLE=hcm_vote_log
